# AI Intelligence Dashboard Configuration
# Copy this to .env.local and fill in values

# Database path (default: ./data/intelligence.db)
DATABASE_URL=./data/intelligence.db

# Demo mode: set to "true" to use seed data without real API calls
DEMO_MODE=false

# Secret key to protect admin and ingestion endpoints
# Generate one with: openssl rand -hex 32
INGEST_API_KEY=

# Optional: Anthropic API key for AI summaries
# ANTHROPIC_API_KEY=

# Optional: GitHub token for higher rate limits
# GITHUB_TOKEN=

# Optional: Webhook URL for alerts
# WEBHOOK_URL=
