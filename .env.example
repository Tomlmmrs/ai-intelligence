# AI Intelligence Dashboard Configuration
# Copy this to .env.local and fill in values

# Turso database (hosted SQLite)
# For local dev without Turso, use: file:./data/intelligence.db
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# Demo mode: set to "true" to use seed data without real API calls
DEMO_MODE=false

# Secret key to protect admin and ingestion endpoints
# Generate one with: openssl rand -hex 32
INGEST_API_KEY=

# Public site URL (for OG tags)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Optional: Anthropic API key for AI summaries
# ANTHROPIC_API_KEY=

# Optional: GitHub token for higher rate limits
# GITHUB_TOKEN=
